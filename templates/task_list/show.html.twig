{% extends 'base.html.twig' %}

{% block title %}{{ task_list.name }}{% endblock %}

{% block body %}
<nav class="mb-6">
    <a href="{{ path('task_list_index') }}" class="inline-flex items-center text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Retour aux listes
    </a>
</nav>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-8">
    <div class="p-8 sm:flex sm:items-center sm:justify-between bg-gradient-to-br from-indigo-50/50 to-white">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">{{ task_list.name }}</h1>
            <p class="mt-2 text-gray-500">
                {{ task_list.tasks|length }} tâche{{ task_list.tasks|length != 1 ? 's' : '' }} au total
            </p>
        </div>
        <div class="mt-4 sm:mt-0 flex gap-3">
            <a href="{{ path('task_list_edit', {id: task_list.id}) }}" class="inline-flex items-center px-4 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                Modifier
            </a>
            <a href="{{ path('task_new', {listId: task_list.id}) }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 transition-all shadow-sm shadow-indigo-200">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Ajouter une tâche
            </a>
        </div>
    </div>

    <div class="divide-y divide-gray-100">
        {% if task_list.tasks is empty %}
            <div class="p-12 text-center text-gray-500">
                <p>Aucune tâche pour le moment. Commencez par en ajouter une !</p>
            </div>
        {% else %}
            {% for task in task_list.tasks|sort((a, b) => a.completed <=> b.completed) %}
                <div class="p-4 sm:px-8 hover:bg-gray-50 transition-colors group flex items-center justify-between">
                    <div class="flex items-center flex-grow">
                        <form method="post" action="{{ path('task_toggle', {listId: task_list.id, id: task.id}) }}" class="mr-4">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_task_' ~ task.id) }}">
                            <button type="submit" class="w-6 h-6 rounded-full border-2 flex items-center justify-center transition-all duration-200 {{ task.completed ? 'bg-indigo-600 border-indigo-600 text-white' : 'border-gray-300 text-transparent hover:border-indigo-400' }}">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                            </button>
                        </form>
                        
                        <div class="flex-grow">
                            <span class="text-lg font-medium transition-all duration-300 {{ task.completed ? 'text-gray-400 line-through' : 'text-gray-900' }}">
                                {{ task.title }}
                            </span>
                        </div>
                    </div>

                    <div class="flex items-center space-x-2 opacity-0 group-hover:opacity-100 transition-opacity">
                        <a href="{{ path('task_edit', {listId: task_list.id, id: task.id}) }}" class="p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all" title="Modifier">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                        
                        <form method="post" action="{{ path('task_delete', {listId: task_list.id, id: task.id}) }}" data-turbo-confirm="Supprimer cette tâche ?">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_task_' ~ task.id) }}">
                            <button type="submit" class="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all" title="Supprimer">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>
{% endblock %}
